# ──────────────────────────────────────────────────────────────────────────────
# JamHub Client — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env.local for local overrides (never commit .env.local).
#
# REQUIRED for production deployment (Vercel, Netlify, etc.)
# ──────────────────────────────────────────────────────────────────────────────

# URL of the deployed JamHub signaling server.
# MUST be https:// in production (browsers block ws:// from https:// pages).
# Set this in Vercel → Project Settings → Environment Variables.
#
# Example (Render):
VITE_SIGNALING_URL=https://jamhub-dtrr.onrender.com
